{
  "config": {
    "step": {
      "user": {
        "title": "AlphaESS Modbus TCP",
        "description": "Verbinde dich mit deinem AlphaESS-Wechselrichter über Modbus TCP. Stelle sicher, dass der Wechselrichter im lokalen Netzwerk erreichbar ist.",
        "data": {
          "host": "Wechselrichter-IP-Adresse",
          "port": "Modbus-Port",
          "slave_id": "Slave-ID"
        }
      },
      "reconfigure": {
        "title": "AlphaESS Modbus TCP neu konfigurieren",
        "description": "Aktualisiere die Verbindungseinstellungen für deinen AlphaESS-Wechselrichter. Vor dem Speichern wird ein Verbindungstest durchgeführt.",
        "data": {
          "host": "Wechselrichter-IP-Adresse",
          "port": "Modbus-Port",
          "slave_id": "Slave-ID"
        }
      }
    },
    "error": {
      "cannot_connect": "Verbindung zum Wechselrichter nicht möglich. Prüfe IP-Adresse, Port und ob Modbus TCP am Wechselrichter aktiviert ist."
    },
    "abort": {
      "already_configured": "Dieser Wechselrichter ist bereits konfiguriert.",
      "reconfigure_successful": "Verbindungseinstellungen erfolgreich aktualisiert."
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Abfragegeschwindigkeit",
        "description": "Lege fest, wie häufig die Integration den Wechselrichter abfragt. Der Modus „Langsam“ reduziert die Transaktionsrate für RS485-Adapter, die zu Timeouts neigen. Der Modus „Schnell“ setzt das Abfrageintervall direkt in Sekunden und skaliert alle Sensor-Abfrageintervalle um denselben Faktor.",
        "data": {
          "poll_mode": "Abfragemodus",
          "slow_multiplier": "Intervall-Multiplikator (langsamer Modus)",
          "fast_multiplier": "Abfrageintervall schneller Modus (s)",
          "model_variant": "Wechselrichter-Modellvariante"
        },
        "data_description": {
          "poll_mode": "Langsam (3-fache Dauer), Normal (Standard) oder Schnell. Im schnellen Modus läuft die Schleife direkt mit dem angegebenen Intervallwert, d. h. 0,1 ergibt eine 100-ms-Schleife und 10 Abfragen pro Sekunde für 1-Sekunden-Sensoren.",
          "slow_multiplier": "Multiplikator, der im langsamen Modus auf alle Abfrageintervalle angewendet wird (Standard 3,0, Bereich 0,25-10,0).",
          "fast_multiplier": "Legt das Abfrageintervall der Koordinator-Schleife in Sekunden fest und skaliert alle Sensor-Abfrageintervalle um denselben Faktor. Bei 0,1 läuft die Schleife alle 100 ms, und 1-Sekunden-Sensoren werden 10-mal pro Sekunde abgefragt. Werte unter 0,25 werden nur für direkte Modbus-TCP-Verbindungen empfohlen – RS485-Adapter kommen damit in der Regel nicht zurecht und können Timeouts verursachen.",
          "model_variant": "Wähle „Standard“ für die meisten Wechselrichter. Wähle „SMILE-B3 / SMILE-B3-PLUS“, wenn dein Wechselrichter ein SMILE-B3 oder SMILE-B3-PLUS ist – diese Modelle verwenden andere Skalierungsfaktoren für Spannungs- und Wechselrichterleistungsregister."
        }
      }
    }
  },

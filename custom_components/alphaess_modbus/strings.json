          "model_variant": "Inverter Model Variant"
        },
        "data_description": {
          "poll_mode": "Slow (3x longer), Normal (default), or Fast (0.5x shorter). Fast mode also reduces the coordinator loop from 2 s to 1 s.",
          "slow_multiplier": "Multiplier applied to all scan intervals in Slow mode (default 3.0, range 0.25-10.0).",
          "fast_multiplier": "Multiplier applied to all scan intervals in Fast mode (default 0.5, range 0.25-10.0). Fast mode on low-spec hardware (Raspberry Pi 3 or similar) may impact Home Assistant performance.",
